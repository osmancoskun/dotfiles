# Copy to ~/.config/sway/wallpaper-daily.env and adjust.
# Used by wallpaper-daily.sh (from scripts/setup/ or stowed home/).
#
# If wallpapers never appear: disable solid swaybg in config.d/99-background-solid.conf
# (image wallpaper and solid colour both use swaybg — 99 loads after 91 by filename order).
#
# Optional: Bing sometimes still returns 403; set a current browser UA string:
# WALLPAPER_UA_BING='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 ...'

# Comma-separated, rotation order (bing | nasa | wikipedia)
WALLPAPER_PROVIDERS=bing,nasa

# Seconds between rotating to the next provider (0 = apply one wallpaper on start, then exit daemon)
WALLPAPER_ROTATE_SEC=300

# Cache directory (filenames: DD-MM-YYYY-<provider>.<ext>)
WALLPAPER_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/wallpapers/daily"

# 1 = on first daemon start only, download today's image for every listed provider (then rotate as usual)
WALLPAPER_PREFETCH_ALL=0

# NASA APOD — use your own key to avoid DEMO_KEY rate limits
NASA_API_KEY=DEMO_KEY

# CLI (also used by scripts/setup/wallpaper.sh menu): --list-today --current-path --apply /path/to.jpg
# --list-today: today's DD-MM-YYYY-* files, or if none, newest *-bing|nasa|wikipedia.* in WALLPAPER_DATA_DIR
# WALLPAPER_QUIET=1 — hide "[wallpaper] swaybg → …" (e.g. when installer calls --apply)

# Curl timeouts (seconds): total wall time per request, shorter for HEAD-only probes
# WALLPAPER_CURL_CONNECT_TIMEOUT=15
# WALLPAPER_CURL_MAX_TIME=120
# WALLPAPER_CURL_MAX_TIME_HEAD=20
# WALLPAPER_CURL_RETRY_MAX_TIME=45
